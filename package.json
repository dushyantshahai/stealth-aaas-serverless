    "@aws-sdk/client-dynamodb": "^3.1002.0",
    "@aws-sdk/client-lambda": "^3.1002.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/client-secrets-manager": "^3.1002.0",
    "@aws-sdk/client-sqs": "^3.1002.0",
    "@aws-sdk/client-textract": "^3.1002.0",
    "@aws-sdk/lib-dynamodb": "^3.1002.0",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1",
