{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "jest"],
    "baseUrl": "./",
    "paths": {
      "@common/*": ["lambda/layers/common/nodejs/*"]
    }
  },
  "include": ["lambda/**/*", "cdk/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "cdk.out"]
}
